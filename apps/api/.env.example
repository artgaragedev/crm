# Postgres / Neon
# DATABASE_URL — pooled connection (host with "-pooler"). Used at runtime.
# Для Neon (serverless, scale-to-zero) обязательно задать пул-параметры, иначе на cold start
# ловим P1001 (can't reach) + P2024 (pool timeout):
#   pgbouncer=true        — идём через PgBouncer-пулер
#   connection_limit=10   — предсказуемый пул вместо дефолтных CPU×2+1 (=33 на Railway)
#   connect_timeout=15    — запас на пробуждение compute
#   pool_timeout=20       — очередь переживает cold start
# Эти же дефолты дозаполняются в коде (prisma.service.ts) — но лучше держать их явно в env.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=10&connect_timeout=15&pool_timeout=20"

# DIRECT_URL — direct connection (same host WITHOUT "-pooler"). Used by prisma migrate.
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# JWT
# В проде: openssl rand -hex 32 — НЕ переиспользовать пример отсюда.
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# CORS / web origin (Vercel URL in prod, http://localhost:3000 in dev)
WEB_ORIGIN="http://localhost:3000"

# Port (Railway provides this automatically in prod)
PORT=4000

# Публичная регистрация. В проде — НЕ выставлять. Если true — любой посетитель сможет
# завести аккаунт STAFF и видеть товары/клиентов. Для bootstrap админа используй prisma:seed.
ENABLE_REGISTRATION=false
