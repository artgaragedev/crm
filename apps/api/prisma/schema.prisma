generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum ProductUnit {
  PCS
  KG
  L
  M
  PACK
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
}

/// Тип значения атрибута. TEXT — обычная строка (M, L, "Стекло"); SWATCH — визуальный (цвет с hex); NUMBER — числовое (объём, вес — храним как строку с unit'ом).
enum AttributeType {
  TEXT
  SWATCH
  NUMBER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements StockMovement[]
  auditLogs AuditLog[]
  lots      StockLot[]
}

// Аудит изменений сущностей. Append-only.
model AuditLog {
  id        String      @id @default(cuid())
  entity    String // 'Product' | 'Variant' | 'Category' | 'Customer' | 'Supplier'
  entityId  String
  action    AuditAction
  userId    String?
  before    Json?
  after     Json?
  note      String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId, createdAt])
  @@index([userId, createdAt])
}

model Category {
  id             String    @id @default(cuid())
  name           String    @unique
  /**
   * Короткий код-префикс (артикул) для использования в SKU: "BTL", "MUG". Опционален, при наличии — uppercase, уникальный.
   */
  code           String?   @unique
  /**
   * Атомарный счётчик артикулов для товаров этой категории: 1, 2, 3... — даёт фиксированный формат KRU000001.
   */
  nextProductSeq Int       @default(1)
  color          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  products Product[]

  @@index([deletedAt])
}

// Родительский товар. Описывает модель ("BOTTLE COLBY"), несёт name/category/description/unit.
// Конкретные SKU и остатки — на ProductVariant.
model Product {
  id          String      @id @default(cuid())
  /// Уникально среди активных (см. partial unique Product_name_active_key в миграции).
  /// Soft-deleted строки не удерживают имя.
  name        String
  /**
   * Короткий артикул товара для 1С: "KRU000001". Уникально среди активных (partial unique).
   */
  code        String?
  description String?
  unit        ProductUnit @default(PCS)
  categoryId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  category   Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants   ProductVariant[]
  attributes ProductAttribute[]

  @@index([categoryId])
  @@index([name])
  @@index([code])
  @@index([deletedAt])
}

// Вариация товара. У каждой свой SKU, цена и остаток.
// attributes — JSON-снапшот (denorm cache: { "COLOR": "BLACK", "SIZE": "M" }), источник правды — VariantAttributeValue.
model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  sku          String   @unique
  attributes   Json     @default("{}")
  /**
   * Продажная цена (selling). Себестоимость живёт на StockLot.
   */
  price        Decimal? @db.Decimal(12, 2)
  reorderLevel Int? // если null — используется глобальный порог дашборда
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product         Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements       StockMovement[]
  lots            StockLot[]
  attributeValues VariantAttributeValue[]

  @@index([productId])
}

/// Тип оси вариативности: "Цвет" (COLOR), "Размер" (SIZE), "Объём" (VOLUME), "Материал" (MATERIAL).
/// Глобальный справочник: один Attribute используется во многих товарах.
model Attribute {
  id        String        @id @default(cuid())
  /**
   * Человекочитаемое имя: "Цвет", "Размер". Уникально.
   */
  name      String        @unique
  /**
   * Короткий машинный код: COLOR, SIZE. Используется в SKU как префикс и в API. Uppercase, A-Z0-9.
   */
  code      String        @unique
  type      AttributeType @default(TEXT)
  /**
   * Единица измерения для type=NUMBER ("мл", "г", "см"). Опционально.
   */
  unit      String?
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  values            AttributeValue[]
  productAttributes ProductAttribute[]
  variantValues     VariantAttributeValue[]

  @@index([deletedAt])
}

/// Допустимое значение оси: RED для COLOR, M для SIZE, 500 для VOLUME (с unit "мл").
/// Уникальность в рамках атрибута: (attributeId, value) и (attributeId, code).
model AttributeValue {
  id          String    @id @default(cuid())
  attributeId String
  /**
   * Нормализованное значение (UPPER, без пробелов): "RED", "ROYAL_BLUE", "500". Источник правды.
   */
  value       String
  /**
   * Человекочитаемая подпись для UI: "Красный", "500 мл". Опционально (по умолчанию value).
   */
  label       String?
  /**
   * Короткий код для SKU: обычно совпадает с value, но может быть короче (RED→R). Опционально (по умолчанию value).
   */
  code        String?
  /**
   * Для type=SWATCH — hex-цвет (#dc2626) или URL картинки.
   */
  swatch      String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  attribute     Attribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantValues VariantAttributeValue[]

  @@unique([attributeId, value])
  @@unique([attributeId, code])
  @@index([attributeId, sortOrder])
  @@index([deletedAt])
}

/// "У товара X используется ось Y". Управляет: набором осей товара, порядком осей в SKU и UI.
model ProductAttribute {
  productId   String
  attributeId String
  /**
   * Порядок оси в SKU и формах. 0 = первая.
   */
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Restrict)

  @@id([productId, attributeId])
  @@index([attributeId])
}

/// "У варианта V значение Z по оси Y". Гарантия: один вариант — одно значение на ось.
model VariantAttributeValue {
  variantId        String
  attributeId      String
  attributeValueId String
  createdAt        DateTime @default(now())

  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute      Attribute      @relation(fields: [attributeId], references: [id], onDelete: Restrict)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Restrict)

  @@id([variantId, attributeId])
  @@index([attributeValueId])
  @@index([attributeId])
}

model Customer {
  id              String    @id @default(cuid())
  name            String
  phone           String?
  email           String?
  note            String?
  /**
   * Постоянная скидка клиента в процентах (0–100). Применяется к продажной цене при OUT-движении; фактическая цена замораживается в StockMovement.unitPrice.
   */
  discountPercent Decimal   @default(0) @db.Decimal(5, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  movements StockMovement[]

  @@index([name])
  @@index([deletedAt])
}

model Supplier {
  id        String    @id @default(cuid())
  name      String
  phone     String?
  email     String?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  movements StockMovement[]
  lots      StockLot[]

  @@index([name])
  @@index([deletedAt])
}

// Журнал движений по вариациям. IN: +qty, OUT: -qty, ADJUST: signed.
// Append-only: вместо удаления создаётся обратное движение со ссылкой через reversesId.
//
// IN/ADJUST+ → создаёт StockLot (1:1 через createdLot).
// OUT/ADJUST- → потребляет существующие lot'ы через LotConsumption (FIFO или manual).
// totalCost — себестоимость движения (для IN: qty × unitCost; для OUT/ADJUST-: сумма потреблённых).
model StockMovement {
  id              String       @id @default(cuid())
  type            MovementType
  variantId       String
  quantity        Decimal      @db.Decimal(14, 3)
  supplierId      String?
  customerId      String?
  userId          String
  note            String?
  /**
   * Себестоимость операции. Null если не определена (для legacy/import).
   */
  totalCost       Decimal?     @db.Decimal(14, 2)
  /**
   * Фактическая цена продажи за единицу (для OUT/ADJUST-). Замораживается в момент сделки — не привязана к Variant.price. Null для IN/ADJUST+ и legacy.
   */
  unitPrice       Decimal?     @db.Decimal(12, 2)
  /**
   * Скидка клиента в момент сделки (audit trail). Null если клиент не указан или у клиента не было скидки.
   */
  discountPercent Decimal?     @db.Decimal(5, 2)
  /**
   * Если это сторнирующее движение — id оригинала, которое оно отменяет.
   */
  reversesId      String?      @unique
  createdAt       DateTime     @default(now())

  variant      ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Restrict)
  supplier     Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  customer     Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user         User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  reverses     StockMovement?   @relation("Storno", fields: [reversesId], references: [id], onDelete: SetNull)
  reversedBy   StockMovement?   @relation("Storno")
  createdLot   StockLot?        @relation("LotCreatedBy")
  consumptions LotConsumption[] @relation("MovementConsumptions")

  @@index([variantId, createdAt])
  @@index([variantId, type])
  @@index([type, createdAt])
  @@index([customerId, createdAt])
  @@index([supplierId, createdAt])
  @@index([userId, createdAt])
}

/// Партия товара — конкретный приход с фиксированной закупочной ценой.
/// Один к одному с движением IN или ADJUST+ (см. createdByMovementId).
model StockLot {
  id                  String   @id @default(cuid())
  variantId           String
  /**
   * Закупочная цена за единицу. 0 для ADJUST+ ("найдено") и для импорта без данных о цене.
   */
  unitCost            Decimal  @db.Decimal(12, 2)
  /**
   * Сколько было в приходе изначально.
   */
  initialQuantity     Decimal  @db.Decimal(14, 3)
  /**
   * Текущий остаток в этой партии (initialQuantity − суммарное потребление).
   */
  remainingQuantity   Decimal  @db.Decimal(14, 3)
  /**
   * Дата прихода — определяет порядок FIFO.
   */
  receivedAt          DateTime
  supplierId          String?
  note                String?
  userId              String
  createdByMovementId String   @unique
  createdAt           DateTime @default(now())

  variant           ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Restrict)
  supplier          Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  user              User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdByMovement StockMovement    @relation("LotCreatedBy", fields: [createdByMovementId], references: [id], onDelete: Cascade)
  consumptions      LotConsumption[]

  @@index([variantId, receivedAt])
  @@index([variantId, remainingQuantity])
}

/// Связь "движение ↔ партия": сколько единиц данное OUT/ADJUST- взяло из конкретной партии.
model LotConsumption {
  id         String   @id @default(cuid())
  lotId      String
  movementId String
  quantity   Decimal  @db.Decimal(14, 3)
  createdAt  DateTime @default(now())

  lot      StockLot      @relation(fields: [lotId], references: [id], onDelete: Restrict)
  movement StockMovement @relation("MovementConsumptions", fields: [movementId], references: [id], onDelete: Cascade)

  @@index([lotId])
  @@index([movementId])
}
